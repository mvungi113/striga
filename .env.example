# Striga Detection Backend Configuration

# Model path (relative or absolute)
MODEL_PATH=./striga/yolo_training/my_model/weights/best.pt

# Server configuration
PORT=5000
DEBUG=False

# CORS configuration
FLASK_ENV=production

# API configuration
MAX_UPLOAD_SIZE_MB=50
INFERENCE_CONFIDENCE_THRESHOLD=0.5

# Device configuration (cuda or cpu)
# Leave empty for auto-detection
DEVICE=auto
